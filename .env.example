# ── Django Backend ─────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-me-in-production-use-a-real-50-char-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL 14 ──────────────────────────────────────────────────────────────
POSTGRES_DB=product_intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=django-db

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Service URLs ───────────────────────────────────────────────────────────────
AGENT_SERVICE_URL=http://localhost:8001
AGENT_SERVICE_API_KEY=change-me-long-random-string
DJANGO_API_BASE_URL=http://localhost:8000

# ── OpenAI / LLM / Nvidia NIM ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_API_BASE_URL=
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0

# ── Provider Integrations ───────────────────────────────────────────────────────
HUBSPOT_API_KEY=
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_API_TOKEN=
JIRA_EMAIL=
LINEAR_API_KEY=
SLACK_BOT_TOKEN=

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
