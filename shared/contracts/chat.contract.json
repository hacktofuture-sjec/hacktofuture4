{
  "version": "0.1.0",
  "endpoint": "POST /api/chat (text/event-stream)",
  "request": {
    "message": "string (optional)",
    "session_id": "string",
    "incident_report": {
      "source_system": "iris",
      "case_id": "string (optional)",
      "report_id": "string (optional)",
      "report_url": "string (optional)",
      "ingested_at": "string (optional)",
      "case_name": "string",
      "short_description": "string",
      "severity": "string",
      "tags": [
        "string"
      ],
      "iocs": [
        "string or object"
      ],
      "timeline": [
        "string or object"
      ]
    }
  },
  "request_rules": {
    "accepted_modes": [
      "message_only",
      "incident_report_only",
      "message_and_incident_report"
    ],
    "precedence": "When incident_report is present, backend derives canonical query context from incident_report and ignores message for controller query input."
  },
  "response": {
    "content_type": "text/event-stream",
    "notes": "Endpoint emits live SSE events while controller executes retrieval, reasoning, and execution stages. Transcript remains available via /api/chat/transcript/{trace_id}."
  },
  "ingestion": {
    "iris": {
      "endpoint": "POST /api/ingest/iris?case_id=<id>",
      "response": {
        "ingested_count": "number",
        "source": "iris",
        "case_id": "string",
        "incident_report": "IncidentReport"
      }
    },
    "confluence": {
      "endpoint": "POST /api/ingest/confluence",
      "request": {
        "page_ids": [
          "string"
        ]
      },
      "response": {
        "ingested_count": "number",
        "failed_count": "number",
        "source": "confluence",
        "results": [
          {
            "page_id": "string",
            "status": "ingested|failed",
            "title": "string|null",
            "error": "string|null"
          }
        ]
      }
    },
    "vector": {
      "status_endpoint": "GET /api/vector/status",
      "rebuild_endpoint": "POST /api/vector/rebuild",
      "response": {
        "source": "vector",
        "status": {
          "mode": "keyword|semantic|hybrid",
          "collection": "string",
          "milvus_host": "string",
          "milvus_port": "number",
          "embedding_provider": "string",
          "indexed": "boolean",
          "doc_count": "number (optional)",
          "last_error": "string|null (optional)"
        }
      }
    }
  },
  "approval": {
    "endpoint": "POST /api/approvals/{trace_id}",
    "request": {
      "decision": "approve|reject",
      "approver_id": "string",
      "comment": "string (optional)"
    },
    "response": {
      "trace_id": "string",
      "final_status": "plan_approved|plan_rejected",
      "execution_mode": "planner_only",
      "approval": {
        "decision": "approve|reject",
        "approver_id": "string",
        "comment": "string",
        "timestamp": "string"
      },
      "execution_result": {
        "tool": "string",
        "status": "string",
        "output": "string",
        "timestamp": "string",
        "execution_mode": "planner_only",
        "no_write_policy": "boolean",
        "plan": "object (optional)"
      }
    }
  },
  "transcript": {
    "endpoint": "GET /api/chat/transcript/{trace_id}",
    "response": {
      "trace_id": "string",
      "suggested_action": "string",
      "action_details": {
        "intent": "string (optional)",
        "tool": "string|null (optional)",
        "parameters": "object (optional)",
        "approval_required": "boolean (optional)",
        "risk_hint": "string|null (optional)"
      },
      "needs_approval": "boolean",
      "execution_status": "string",
      "execution_mode": "string (optional)",
      "final_status": "string (optional)",
      "approval": "object (optional)",
      "execution_result": "object (optional)",
      "dedup_summary": {
        "documents": {
          "scanned": "number",
          "duplicates": "number"
        },
        "transcripts": {
          "scanned": "number",
          "duplicates": "number"
        },
        "deduped_count": "number",
        "duplication_ratio": "number",
        "last_run_at": "string|null"
      },
      "steps": [
        {
          "step": "string",
          "agent": "string",
          "observation": "string",
          "sources": [
            {
              "title": "string",
              "path": "string",
              "source_type": "string (optional)",
              "score": "number (optional)"
            }
          ],
          "timestamp": "string",
          "metadata": {
            "retrieval_method": "string (optional)",
            "query_tokens": [
              "string"
            ],
            "llm_query_expansion": "object (optional)",
            "vector_db": "object (optional)",
            "confidence": "number (optional)",
            "confidence_breakdown": "object (optional)",
            "reasoning_steps": [
              "string"
            ],
            "evidence_scores": [
              {
                "title": "string",
                "path": "string",
                "source_type": "string",
                "raw_score": "number",
                "priority_score": "number"
              }
            ],
            "action_details": "object (optional)",
            "risk_level": "string (optional)",
            "requires_human_approval": "boolean (optional)",
            "execution_reasoning": "string (optional)",
            "execution_mode": "string (optional)",
            "no_write_policy": "boolean (optional)",
            "provider": "string (optional)",
            "model": "string (optional)",
            "risk_hint": "string (optional)"
          }
        }
      ]
    }
  },
  "stream": {
    "endpoint": "POST /api/chat",
    "transport": "SSE",
    "sse_fields": {
      "id": "trace_id:sequence",
      "event": "trace_started|trace_step|trace_heartbeat|trace_complete|trace_error",
      "data": "json payload"
    },
    "event_envelope": {
      "event_type": "string",
      "event_id": "string",
      "trace_id": "string",
      "sequence": "number",
      "timestamp": "string",
      "status": "string",
      "metadata": "object (optional)"
    },
    "trace_step_payload": {
      "step": "string",
      "agent": "string",
      "observation": "string",
      "sources": [
        {
          "title": "string",
          "path": "string",
          "source_type": "string (optional)",
          "score": "number (optional)"
        }
      ],
      "metadata": {
        "retrieval_method": "string (optional)",
        "query_tokens": [
          "string"
        ],
        "llm_query_expansion": "object (optional)",
        "vector_db": "object (optional)",
        "confidence": "number (optional)",
        "confidence_breakdown": "object (optional)",
        "reasoning_steps": [
          "string"
        ],
        "evidence_scores": [
          {
            "title": "string",
            "path": "string",
            "source_type": "string",
            "raw_score": "number",
            "priority_score": "number"
          }
        ],
        "action_details": "object (optional)",
        "risk_level": "string (optional)",
        "requires_human_approval": "boolean (optional)",
        "execution_reasoning": "string (optional)",
        "provider": "string (optional)",
        "model": "string (optional)",
        "risk_hint": "string (optional)",
        "started_at": "string (optional)",
        "finished_at": "string (optional)",
        "duration_ms": "number (optional)"
      }
    },
    "trace_complete_payload": {
      "answer": "string",
      "needs_approval": "boolean",
      "suggested_action": "string|null",
      "metadata": {
        "dedup_summary": "object",
        "action_details": "object (optional)",
        "execution_status": "string (optional)",
        "execution_mode": "string (optional)",
        "step_count": "number"
      }
    },
    "trace_error_payload": {
      "error_code": "string",
      "error": "string"
    }
  }
}
