          "refId": "B",
          "datasource": "Parseable",
          "rawSql": "SELECT time, metadata FROM tetragon ORDER BY time DESC LIMIT 50",
          "format": "logs"
        }
      ]
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
