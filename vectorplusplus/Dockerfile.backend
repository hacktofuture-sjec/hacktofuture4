FROM python:3.11-slim

WORKDIR /app
# Install system dependencies if any are needed (e.g. for psycopg2/scikit-learn)
RUN apt-get update && apt-get install -y gcc g++ libpq-dev && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Overridden by docker-compose volume, but good for standalone
COPY backend /app
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
